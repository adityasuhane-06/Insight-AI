# ZyLabs AI Research Copilot — Environment Configuration
# Copy this file to .env and fill in your actual values

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose: "gemini" (recommended, free tier available) or "openai"
LLM_PROVIDER=gemini

# Google Gemini API Key — get one free at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key — only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Optionally override the model (leave empty for auto-selection)
# LLM_MODEL=gemini-2.0-flash

# ─── Search Provider ──────────────────────────────────────────────────────────
# Tavily API key — get free tier at: https://app.tavily.com/
# Leave empty to use DuckDuckGo (no key needed, but slower)
TAVILY_API_KEY=your_tavily_api_key_here

# ─── App Settings ─────────────────────────────────────────────────────────────
DEBUG=false
MAX_RETRIES=2
QUALITY_THRESHOLD=0.65
MAX_SEARCH_RESULTS=5
